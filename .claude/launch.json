{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agentops-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "src/index.ts"],
      "port": 4000,
      "cwd": "apps/server"
    },
    {
      "name": "agentops-web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--port", "3000"],
      "port": 3000,
      "cwd": "apps/web"
    }
  ]
}
